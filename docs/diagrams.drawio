        <mxCell id="vGL5r9Kn3q6MbAQNf-LS-3" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;rounded=0;" value="&lt;span style=&quot;font-size: 20px;&quot;&gt;SSHes into the VM and installs python3 (Ansible&#39;s SSH transport needs it on the remote end). Retriggers if vm_host changes.&lt;/span&gt;" vertex="1">
